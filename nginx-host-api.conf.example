# nginx-host-api.conf.example
# 2026-06-11 hoyeon.han: Oracle Cloud 호스트 nginx 용 발주내역 API 프록시 설정 예시 (신규)
#
# 용도:
#   원격서버(Oracle Cloud)에 직접 설치된 nginx 에 /api/ 경로를 추가해서
#   docker 컨테이너(sollume-api, 127.0.0.1:8502)로 전달한다.
#   ※ 루트의 nginx.conf 는 로컬/NAS 의 docker nginx 컨테이너용이므로 혼동 주의.
#
# 적용 방법 (원격서버에서):
#   1) 기존 nginx 설정에서 사용 중인 server 블록을 찾는다
#      - 보통 /etc/nginx/sites-enabled/* 또는 /etc/nginx/conf.d/*.conf
#   2) 해당 server { ... } 블록 안에 아래 "location /api/" 블록을 붙여넣는다
#   3) 문법 검사 후 재적용:
#      sudo nginx -t
#      sudo systemctl reload nginx
#   4) 확인:
#      curl http://localhost/api/health        → {"status":"ok"}
#      curl -H "X-API-Key: <키>" http://localhost/api/order-file/meta
#
# 전제:
#   - docker-compose.cloud.yml 의 sollume-api 가 127.0.0.1:8502 로 떠 있어야 한다
#   - API 인증 키(.env 의 ORDER_API_KEY)는 Flask 가 검사하므로 nginx 에는 설정 불필요

# ---------------- 아래 블록을 기존 server { } 안에 추가 ----------------

location /api/ {
    proxy_pass http://127.0.0.1:8502;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;  # 큰 파일 다운로드/시트 파싱 대기
}

# ---------------- (선택) Streamlit 화면도 같은 nginx 로 통합하려면 ----------------
# 현재 Streamlit 은 8501 포트로 직접 노출 중이다. 원하면 아래 블록을 추가해
# 80/443 으로 통합할 수 있다 (WebSocket 설정 필수). 이 경우 http 블록(또는 해당
# 설정 파일 상단)에 다음 map 이 한 번 정의되어 있어야 한다:
#
#   map $http_upgrade $connection_upgrade {
#       default upgrade;
#       ''      close;
#   }
#
# location / {
#     proxy_pass http://127.0.0.1:8501;
#     proxy_http_version 1.1;
#     proxy_set_header Upgrade           $http_upgrade;
#     proxy_set_header Connection        $connection_upgrade;
#     proxy_set_header Host              $host;
#     proxy_set_header X-Real-IP         $remote_addr;
#     proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
#     proxy_read_timeout 86400s;  # WebSocket 장시간 연결 유지
# }
